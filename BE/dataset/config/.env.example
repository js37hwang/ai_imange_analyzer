### ===== 본인에 맞는 데이터를 집어 넣고 파일명을 .env로 변경 후 사용하세요

# port
MAIN_PORT=main.ipynb 서버 사용 포트 번호
ANALYZE_PORT=analyze.ipynb 서버 사용 포트 번호
OCR_PORT=ocr.ipynb 서버 사용 포트 번호

# server url
# integrated gateway server
MAIN_SERVER_URL=main 서버 url+ port
# analyze server- Ollama/GPT
ANALYZE_SERVER_URL=analyze 서버 url+ port
# OCR server- Chandra 
OCR_SERVER_URL=ocr 서버 url+ port

# 허깅페이스 토큰
HF_TOKEN=허깅페이스 로그인용 토큰

# analyze
USE_MODEL=OPEN_AI 또는 OLLAMA 입력
#OPEN_AI #OLLAMA
#OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ollama에서 사용할 ai 모델
OPENAI_API_KEY=open ai api key
OPENAI_MODEL=open ai 모델명

# db
DB_HOST=디비 주소
DB_USER=로그인 아이디
DB_PASSWORD=패스워드
DB_NAME=디비명